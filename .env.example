# Database location
DATABASE_URL=./data/duomi.db

# Enable demo data seeding (seeding mock values on startup if database tables are empty)
DEMO_MODE=false

# User display names
PUBLIC_PERSON_A_NAME=Partner A
PUBLIC_PERSON_B_NAME=Partner B

# Localization settings
LOCALE=en-US
CURRENCY=USD

# Passphrase protection (set for public self-hosting, leave empty to disable auth)
SECRET_APP_PASSPHRASE=dummy_passphrase_for_testing

